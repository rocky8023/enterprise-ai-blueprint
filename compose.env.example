# ============================================================
# enterprise-ai-blueprint 环境变量配置
# 复制此文件为 .env，按需修改：
#   cp compose.env.example .env
#
# .env 已在 .gitignore，不会被提交。
# ============================================================

# ---------- 必填：API Key ----------
BLUEPRINT_CHAT_API_KEY=your_chat_api_key_here
BLUEPRINT_EMBEDDING_API_KEY=your_embedding_api_key_here

# ---------- 可选：切换厂商 (Preset 方式) ----------
# 内置 preset: minimax / dashscope / deepseek / glm / kimi / openai
# 默认 chat=minimax, embedding=dashscope
#
# 切厂商只改一个名字，base-url 和推荐 model 自动从 providers.yml 解析。
# 列出所有可用 preset: GET /api/providers

# === 默认（注释掉就是这套）===
# BLUEPRINT_CHAT_PRESET=minimax
# BLUEPRINT_EMBEDDING_PRESET=dashscope

# === 切 chat 到 DeepSeek（embedding 仍走 DashScope）===
# BLUEPRINT_CHAT_PRESET=deepseek

# === 切 chat 到智谱 GLM ===
# BLUEPRINT_CHAT_PRESET=glm

# === 切 chat 到 Kimi ===
# BLUEPRINT_CHAT_PRESET=kimi

# === 用 OpenAI 做 chat + embedding（需翻墙）===
# BLUEPRINT_CHAT_PRESET=openai
# BLUEPRINT_EMBEDDING_PRESET=openai

# ---------- 可选：显式覆盖 preset 中的字段 ----------
# 任何 BLUEPRINT_*_BASE_URL / BLUEPRINT_*_MODEL 都会覆盖 preset 推荐值。
# 适合：同一家厂商换更便宜版本、走内网代理、临时实验等。
#
# # 用 minimax preset，但切到便宜的 MiniMax-Text-01:
# BLUEPRINT_CHAT_PRESET=minimax
# BLUEPRINT_CHAT_MODEL=MiniMax-Text-01
#
# # 用 deepseek preset，但走内网 LLM 代理:
# BLUEPRINT_CHAT_PRESET=deepseek
# BLUEPRINT_CHAT_BASE_URL=https://llm-proxy.intra.example.com

# ---------- 可选：请求维度切 chat (ChatRouter) ----------
# 上面是“启动期定默认厂商”；若要在单次请求里临时切到别的 preset
# （GET /api/rag/ask?preset=deepseek），需为该 preset 单独配 key：
#   变量名规则 BLUEPRINT_KEY_<PRESET大写>
# BLUEPRINT_KEY_DEEPSEEK=sk-xxx
# BLUEPRINT_KEY_GLM=xxx
# 默认 preset 仍复用上面的 BLUEPRINT_CHAT_API_KEY，无需重复配置。

# ---------- 可选：Langfuse 调用追踪 ----------
# 默认关闭。开启后每次 LLM 调用异步推送到 Langfuse（trace + generation + token + 成本）。
# BLUEPRINT_LANGFUSE_ENABLED=true
# BLUEPRINT_LANGFUSE_PUBLIC_KEY=pk-lf-xxx
# BLUEPRINT_LANGFUSE_SECRET_KEY=sk-lf-xxx
# 自托管再改 host（默认 https://cloud.langfuse.com）:
# BLUEPRINT_LANGFUSE_HOST=https://your-langfuse

# ---------- Spring profile ----------
# SPRING_PROFILES_ACTIVE=prod
