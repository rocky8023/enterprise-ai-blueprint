# ============================================================
# enterprise-ai-blueprint 环境变量配置
# 复制此文件为 .env，按需修改：
#   cp compose.env.example .env
#
# .env 已在 .gitignore，不会被提交。
# ============================================================

# ---------- 必填：API Key ----------
BLUEPRINT_CHAT_API_KEY=your_chat_api_key_here
BLUEPRINT_EMBEDDING_API_KEY=your_embedding_api_key_here

# ---------- 可选：自定义 chat 厂商 ----------
# 不设置则使用默认 MiniMax 中国版 + MiniMax-M2.7

# === 默认（MiniMax 中国版）===
# BLUEPRINT_CHAT_BASE_URL=https://api.minimaxi.com
# BLUEPRINT_CHAT_MODEL=MiniMax-M2.7

# === 切到 DeepSeek ===
# BLUEPRINT_CHAT_BASE_URL=https://api.deepseek.com
# BLUEPRINT_CHAT_MODEL=deepseek-chat

# === 切到 OpenAI（需翻墙）===
# BLUEPRINT_CHAT_BASE_URL=https://api.openai.com
# BLUEPRINT_CHAT_MODEL=gpt-4o-mini

# === 切到智谱 GLM ===
# BLUEPRINT_CHAT_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# BLUEPRINT_CHAT_MODEL=glm-4.5

# === 切到 Moonshot Kimi ===
# BLUEPRINT_CHAT_BASE_URL=https://api.moonshot.cn
# BLUEPRINT_CHAT_MODEL=moonshot-v1-8k

# ---------- 可选：自定义 embedding 厂商 ----------
# 不设置则使用默认 DashScope (阿里通义) + text-embedding-v3

# === 默认（DashScope）===
# BLUEPRINT_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
# BLUEPRINT_EMBEDDING_MODEL=text-embedding-v3

# === 切到智谱 embedding ===
# BLUEPRINT_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# BLUEPRINT_EMBEDDING_MODEL=embedding-3

# === 切到 OpenAI embedding ===
# BLUEPRINT_EMBEDDING_BASE_URL=https://api.openai.com
# BLUEPRINT_EMBEDDING_MODEL=text-embedding-3-small

# ---------- Spring profile ----------
# SPRING_PROFILES_ACTIVE=prod
